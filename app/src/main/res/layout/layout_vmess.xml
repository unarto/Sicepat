<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <include layout="@layout/layout_address_port" />

        <!-- VMess specific field (UUID) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UUID / User ID"
                android:textColor="#B0C1D4" />

            <EditText
                android:id="@+id/et_uuid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@android:color/white"
                android:hint="e.g. 00000000-0000-0000-0000-000000000000"
                android:textColorHint="#5F6D7E" />
        </LinearLayout>

        <include layout="@layout/layout_transport" />

        <include layout="@layout/layout_tls" />

    </LinearLayout>
</ScrollView>
